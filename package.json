{
  "name": "datalad-desktop",
  "version": "0.1.7",
  "private": true,
  "type": "module",
  "main": "src/gui/main.js",
  "description": "DataLad Desktop cross-platform project workflow app",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-include=\"src/datalad/**\" --test-coverage-lines=85 --test-coverage-functions=85 --test-coverage-branches=75",
    "test:coverage:lcov": "node -e \"require('node:fs').mkdirSync('coverage', { recursive: true })\" && node --test --experimental-test-coverage --test-coverage-include=\"src/datalad/**\" --test-reporter=lcov --test-reporter-destination=coverage/lcov.info --test-reporter=spec --test-reporter-destination=stdout",
    "test:rust:core": "cd rust-core && cargo test",
    "test:rust:addon": "cd native/rust-core-node && cargo test",
    "build:rust:addon": "cd native/rust-core-node && npm install && npm run build",
    "test:bridge": "node --test test/rust-bridge.test.js",
    "test:parity": "node --test test/adapter-parity.test.js",
    "package:dir": "electron-builder --dir",
    "package:dist": "electron-builder",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:mac:x64": "electron-builder --mac --x64",
    "package:mac:arm64": "electron-builder --mac --arm64",
    "package:mac:both": "electron-builder --mac --x64 --arm64",
    "package:win:x64": "electron-builder --win --x64",
    "package:platforms": "npm run package:mac:both && npm run package:win:x64"
  },
  "build": {
    "appId": "org.datalad.desktop",
    "productName": "DataLad Desktop",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "src/gui/assets/icons/datalad_desktop.icns"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/gui/assets/icons/datalad_desktop.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Science",
      "icon": "src/gui/assets/icons/datalad_desktop.png"
    }
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  },
  "engines": {
    "node": ">=20"
  }
}
